            sun_opacity.animate.set_value(0),
            night_overlay.animate.set_fill("#050816", opacity=0.72),
            title.animate.become(Text("T2S: Night-Time Settlement", font_size=40).to_edge(UP)),
            FadeOut(rts),
            run_time=1.6,
            rate_func=smooth
        )

        moon = Circle(
            radius=0.45,
            color=GRAY_B,
            fill_color=GRAY_B,
            fill_opacity=0.9,
            stroke_width=0
        ).move_to(self.camera.frame.get_corner(UP + RIGHT) + LEFT * 0.8 + DOWN * 0.6)

        moon_cut = Circle(
            radius=0.45,
            color="#050816",
            fill_color="#050816",
            fill_opacity=1,
            stroke_width=0
        ).move_to(moon.get_center() + RIGHT * 0.18 + UP * 0.06)

        moon_group = VGroup(moon, moon_cut)

        clock = Text("20:30", font_size=36, color=GRAY_B)
        clock.next_to(moon_group, DOWN, buff=0.3)

        self.play(
            FadeIn(moon_group, shift=DOWN * 0.2),
            FadeIn(clock),
            FadeOut(transition_text),
            run_time=0.8
        )

        self.play(
            self.camera.frame.animate.scale(0.7).move_to(ORIGIN),
            run_time=1.2,
            rate_func=smooth
        )

        incoming_cards = VGroup(*onhold_cards[:4])
        self.play(FadeOut(incoming_cards), run_time=0.4)
        self.play(FadeOut(title), run_time=0.3)

        self.mcm_graph_animation(incoming_cards)

        cash = {"A": 80, "B": 40, "C": 70}
        securities = {"A": 30, "B": 80, "C": 50}
        capacity = 100

        cash_tanks = {}
        sec_tanks = {}

        cash_group = VGroup()
        sec_group = VGroup()

        for bank in ["A", "B", "C"]:
            cash_tank = Tank(f"Cash {bank}", cash[bank], capacity, GREEN)
            sec_tank = Tank(f"Sec. {bank}", securities[bank], capacity, BLUE)

            cash_tanks[bank] = cash_tank
            sec_tanks[bank] = sec_tank

            cash_group.add(cash_tank)
            sec_group.add(sec_tank)

        cash_group.arrange(DOWN, buff=0.65).move_to(LEFT * 5.4 + DOWN * 0.45)
        sec_group.arrange(DOWN, buff=0.65).move_to(RIGHT * 5.4 + DOWN * 0.45)

        cash_title = Text("Cash accounts", font_size=22, color=GREEN)
        sec_title = Text("Securities accounts", font_size=22, color=BLUE)

        cash_title.next_to(cash_group, UP, buff=0.3)
        sec_title.next_to(sec_group, UP, buff=0.3)

        engine, engine_box = self.make_engine()

        self.play(
            FadeIn(cash_title),
            FadeIn(sec_title),
            LaggedStart(*[FadeIn(t) for t in cash_group], lag_ratio=0.12),
            LaggedStart(*[FadeIn(t) for t in sec_group], lag_ratio=0.12),
            FadeIn(engine),
            run_time=1.2
        )

        transactions = [
            ("A", "B", 30, "DVP", True),
            ("C", "A", 20, "Cash transfer", True),
            ("B", "C", 40, "DVP", True),
            ("A", "C", 60, "DVP", False),
        ]

        tx_cards = VGroup()

        for i, (buyer, seller, amount, movement_type, selected) in enumerate(transactions, start=1):
            if movement_type == "Cash transfer":
                tx_cards.add(self.small_data_card(f"T{i}: cash {buyer} → {seller}", GREEN, width=3.2))
            else:
                tx_cards.add(self.small_data_card(f"T{i}: cash {buyer} → {seller} sec. {seller} → {buyer}", GREEN, width=3.8))

        tx_cards.arrange(DOWN, buff=0.16)
        tx_cards.move_to(engine_box.get_center() + DOWN * 0.35)

        intro = Text(
            "MOM receives pending transactions.",
            font_size=24,
            color=YELLOW,
        ).to_edge(DOWN)

        self.play(FadeIn(intro))
        self.play(
            LaggedStart(
                *[FadeIn(card, shift=DOWN * 0.1) for card in tx_cards],
                lag_ratio=0.12,
            )
        )

        self.wait(1.0)
        self.play(FadeOut(intro))

        thinking = Text(
            "MOM searches for a feasible settlment by looking at the whole set.",
            font_size=24,
            color=GRAY_B,
        ).to_edge(DOWN)

        self.play(FadeIn(thinking))

        selected_rects = VGroup()

        for i, (_, _, _, _, selected) in enumerate(transactions):
            color = GREEN if selected else RED
            rect = SurroundingRectangle(
                tx_cards[i],
                color=color,
                buff=0.035,
                stroke_width=2.4,
            )
            selected_rects.add(rect)

        self.play(
            LaggedStart(
                *[Create(rect) for rect in selected_rects],
                lag_ratio=0.15,
            )
        )

        decision = Text(
            "Green settles now. Red waits.",
            font_size=25,
            color=WHITE,
        ).to_edge(DOWN)

        self.play(Transform(thinking, decision))
        self.wait(1.2)
        self.play(FadeOut(thinking))

        selected_plan = VGroup(
            Text("Settlement plan", font_size=22, color=YELLOW),
            Text("T1, T2, T3 selected", font_size=20, color=GREEN),
            Text("T4 postponed", font_size=20, color=RED),
        )

        selected_plan.arrange(DOWN, buff=0.18)
        selected_plan.move_to(engine_box.get_center() + DOWN * 0.45)

        self.play(FadeOut(tx_cards), FadeOut(selected_rects))
        self.play(FadeIn(selected_plan))
        self.wait(1)

        execute = Text(
            "T2S executes the selected movements.",
            font_size=25,
            color=YELLOW,
        ).to_edge(DOWN)

        self.play(FadeIn(execute))
        self.wait(0.8)

        selected_transactions = [
            ("A", "B", 30, "DVP"),
            ("C", "A", 20, "Cash transfer"),
            ("B", "C", 40, "DVP"),
        ]

        for i, (buyer, seller, amount, movement_type) in enumerate(selected_transactions, start=1):
            if movement_type == "Cash transfer":
                tx_text = Text(
                    f"T{i}: cash transfer only: {buyer} → {seller}",
                    font_size=21,
                    color=GREEN,
                ).to_edge(DOWN)
            else:
                tx_text = Text(
                    f"T{i}: cash {buyer} → {seller}, securities {seller} → {buyer}",
                    font_size=21,
                    color=YELLOW,
                ).to_edge(DOWN)

            self.play(Transform(execute, tx_text), run_time=0.35)

            self.outside_bezier_transfer(cash_tanks[buyer], cash_tanks[seller], GREEN, side="left")

            cash[buyer] -= amount
            cash[seller] += amount

            self.play(
                cash_tanks[buyer].update_amount(cash[buyer]),
                cash_tanks[seller].update_amount(cash[seller]),
                run_time=0.4,
            )

            if movement_type == "DVP":
                self.outside_bezier_transfer(sec_tanks[seller], sec_tanks[buyer], BLUE, side="right")

                securities[seller] -= amount
                securities[buyer] += amount

                self.play(
                    sec_tanks[seller].update_amount(securities[seller]),
                    sec_tanks[buyer].update_amount(securities[buyer]),
                    run_time=0.4,
                )

        self.play(FadeOut(execute), FadeOut(selected_plan))

        recap = VGroup(
            Text("Key idea", font_size=34, color=YELLOW),
            Text(
                "MCM compute metrics of the problem",
                font_size=29,
                color=WHITE,
                line_spacing=1.15,
            ),
            Text(
                "MOM maximizes the settlement ratio",
                font_size=25,
                color=GRAY_B,
            ),
        )

        recap.arrange(DOWN, buff=0.35)
        recap.move_to(ORIGIN)

        self.play(FadeOut(engine))
        self.play(FadeIn(recap))
        self.wait(2.5)

        self.play(FadeOut(recap))



        self.play(
            FadeOut(cash_group),
            FadeOut(sec_group),
            FadeOut(cash_title),
            FadeOut(sec_title),
            FadeOut(moon_group),
            FadeOut(clock)
        )
        self.wait(3)
