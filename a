    def outside_bezier_transfer(self, source_tank, target_tank, color, side="left"):
        if side == "left":
            start = source_tank.border.get_left()
            end = target_tank.border.get_left()
            path = CubicBezier(start, start + LEFT * 1.45, end + LEFT * 1.45, end)
        else:
            start = source_tank.border.get_right()
            end = target_tank.border.get_right()
            path = CubicBezier(start, start + RIGHT * 1.45, end + RIGHT * 1.45, end)

        trail = VMobject()
        trail.set_points(path.points)
        trail.set_stroke(color=color, width=4, opacity=0.9)

        dot = Dot(start, radius=0.10, color=color)

        self.play(Create(trail), FadeIn(dot), run_time=0.20)
        self.play(MoveAlongPath(dot, path), run_time=0.45, rate_func=smooth)
        self.play(Flash(end, color=color, flash_radius=0.28), run_time=0.22)
        self.play(FadeOut(dot), FadeOut(trail), run_time=0.15)

