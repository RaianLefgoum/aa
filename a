def return_suns(sun_origin):
    sun_opacity = ValueTracker(0.2)
    COLORS_SUN = [YELLOW_A, YELLOW_B, YELLOW_C, YELLOW_D]

    def get_sun(i):
        return lambda: Circle(
            radius=0.6 * (i + 1),
            color=COLORS_SUN[i],
            stroke_width=0
        ).set_opacity(
            sun_opacity.get_value() * (i + 1) / 3
        ).move_to(sun_origin)

    suns = Group(*[always_redraw(get_sun(i)) for i in range(len(COLORS_SUN))])
    return suns, sun_opacity


class TransactionRect(VGroup):
    def __init__(
        self,
        *attributes,
        width=4.75, height=1.55,
        stroke_color=WHITE,
        fill_color=BLUE_E,
        fill_opacity=0.08,
        font_size=22,
        **kwargs
    ):
        super().__init__(**kwargs)

        if len(attributes) % 2 != 0:
            raise ValueError("TransactionRect expects name/value attribute pairs")

        pairs = list(zip(attributes[0::2], attributes[1::2]))
        n_lines = len(pairs)
        actual_height = max(1.15, 0.43 * n_lines + 0.38)

        rect = Rectangle(
            width=width,
            height=actual_height,
            stroke_color=stroke_color,
            stroke_width=2.5,
            fill_color=fill_color,
            fill_opacity=fill_opacity,
            z_index=1,
        )

        lines = VGroup(*[
            Text(f"{name}: {value}", font_size=font_size)
            for name, value in pairs
        ]).arrange(DOWN, aligned_edge=LEFT, buff=0.08)

        lines.move_to(rect.get_center()).align_to(rect, LEFT).shift(RIGHT * 0.28)

        self.add(rect, lines)
        self.rect = rect
        self.lines = lines


class Tank(VGroup):
    def __init__(self, label, amount, capacity, color, width=0.9, height=1.0, **kwargs):
        super().__init__(**kwargs)

        self.account_label = label
        self.capacity = capacity
        self.color = color
        self.w = width
        self.h = height

        self.border = RoundedRectangle(
            width=width,
            height=height,
            corner_radius=0.08,
            stroke_color=WHITE,
            stroke_width=2,
            fill_opacity=0,
        )

        fill_ratio = max(0, min(amount / capacity, 1))
        fill_height = fill_ratio * height

        self.fill = Rectangle(
            width=width,
            height=max(fill_height, 0.001),
            stroke_width=0,
            fill_color=color,
            fill_opacity=0.75,
        )

        self.fill.align_to(self.border, DOWN)
        self.fill.move_to(self.border.get_bottom() + UP * fill_height / 2)

        self.label = Text(label, font_size=13)
        self.value = Text(str(amount), font_size=15, color=WHITE)

        self.label.next_to(self.border, UP, buff=0.08)
        self.value.move_to(self.border.get_center())

        self.add(self.border, self.fill, self.label, self.value)

    def update_amount(self, amount):
        new_tank = Tank(
            self.account_label,
            amount,
            self.capacity,
            self.color,
            self.w,
            self.h,
        )
        new_tank.move_to(self)
        return Transform(self, new_tank)


