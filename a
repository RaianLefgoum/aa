    def make_resource_graph(self, graph_title, center, color, node_labels, edge_specs, curved_edges=None):
        curved_edges = curved_edges or {}
        graph_box = RoundedRectangle(
            width=3.25,
            height=2.35,
            corner_radius=0.18,
            stroke_color=color,
            stroke_width=2.5,
            fill_color="#101b36",
            fill_opacity=0.96,
        ).move_to(center)

        title = Text(graph_title, font_size=16, color=color)
        title.next_to(graph_box, UP, buff=0.10)

        positions = {
            "A": graph_box.get_center() + LEFT * 0.78 + UP * 0.38,
            "B": graph_box.get_center() + RIGHT * 0.78 + UP * 0.38,
            "C": graph_box.get_center() + DOWN * 0.52,
        }

        nodes = {}
        node_group = VGroup()
        for name, pos in positions.items():
            circle = Circle(
                radius=0.22,
                color=WHITE,
                fill_color="#23345f",
                fill_opacity=0.95,
            ).move_to(pos)
            label = Text(node_labels[name], font_size=9, color=WHITE).move_to(circle)
            group = VGroup(circle, label)
            nodes[name] = group
            node_group.add(group)

        edge_group = VGroup()
        label_group = VGroup()
        label_offsets = [UP * 0.15, DOWN * 0.15, LEFT * 0.15, RIGHT * 0.15]
        for k, (u, v, label) in enumerate(edge_specs):
            curve_angle = curved_edges.get(label, 0)
            start = nodes[u].get_center()
            end = nodes[v].get_center()

            if curve_angle:
                # Curved arrows make opposite-direction transactions clearly distinct.
                edge = CurvedArrow(
                    start,
                    end,
                    angle=curve_angle,
                    color=color,
                    stroke_width=2.0,
                    tip_length=0.12,
                )
                label_direction = normalize(edge.get_center() - graph_box.get_center())
                if np.linalg.norm(label_direction) < 1e-6:
                    label_direction = UP
                label_pos = edge.get_center() + label_direction * 0.18
            else:
                edge = Arrow(
                    start,
                    end,
                    buff=0.30,
                    stroke_width=2.0,
                    color=color,
                    max_tip_length_to_length_ratio=0.12,
                )
                label_pos = edge.get_center() + label_offsets[k % len(label_offsets)]

            txt = Text(label, font_size=9, color=YELLOW)
            txt.move_to(label_pos)
            edge_group.add(edge)
            label_group.add(txt)

        return VGroup(graph_box, title, node_group, edge_group, label_group), graph_box, node_group, edge_group, label_group

